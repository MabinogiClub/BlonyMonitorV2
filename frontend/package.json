{
  "name": "blonymonitorv2-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "preinstall": "node -e \"const v=process.versions.node.split('.').map(Number);const ok=(v[0]===20&&v[1]>=19)||(v[0]===22&&v[1]>=12)||v[0]>22;if(!ok){console.error('\\x1b[31m错误: 需要 Node.js 20.19+ 或 22.12+，当前版本: '+process.version+'\\x1b[0m');process.exit(1)}\"",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@jamescoyle/vue-icon": "^0.1.2",
    "@mdi/js": "^7.4.47",
    "echarts": "^6.0.0",
    "pinia": "^3.0.4",
    "vant": "^4.9.17",
    "vue": "^3.5.26",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "sass": "^1.97.2",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^28.7.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.2"
  }
}
